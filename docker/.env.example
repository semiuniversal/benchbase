# Copy to .env and set absolute host paths (required for Portainer bind mounts).
# Example: cp .env.example .env

# Host directory for SQLite DB, WAL files, run_logs/, server state (must persist).
# Create before first deploy: mkdir -p /path/to/benchbase/docker/data
BENCHBASE_HOST_DATA=/path/to/benchbase/docker/data

# Host config directory (settings.yaml — writable; UI saves settings here).
BENCHBASE_HOST_CONFIG=/path/to/benchbase/config

# Published port on the host.
BENCHBASE_PORT=8000

# LiteLLM from inside the container (use host.docker.internal on Docker Desktop / Linux 20.10+).
# Override in config/settings.yaml or set here if you add env wiring later.
# LITELLM_BASE_URL=http://host.docker.internal:4000
